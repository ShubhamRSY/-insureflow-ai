# ── Unified fallback (used if *_CHEAP_* or *_EXPENSIVE_* are not set) ──
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# ── Tier 1: Cheap / fast model for specialist agents (RiskAnalyst, LossRun, etc.) ──
LLM_CHEAP_PROVIDER=openai
LLM_CHEAP_MODEL=gpt-4o-mini
LLM_CHEAP_API_KEY=
# LLM_CHEAP_BASE_URL=http://localhost:8000/v1   # optional: self-hosted vLLM

# ── Tier 2: Expensive / high-quality model for UW decision + conflict resolution ──
LLM_EXPENSIVE_PROVIDER=openai
LLM_EXPENSIVE_MODEL=gpt-4o
LLM_EXPENSIVE_API_KEY=
# LLM_EXPENSIVE_BASE_URL=

# ── Claude / Anthropic (alternative provider) ──
# Set provider to "anthropic" or "claude" to use Claude models
# CLAUDE_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Auth ──
SECRET_KEY=CHANGE_ME_TO_A_LONG_SECRET_KEY_IN_PRODUCTION
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Storage ──
AUDIT_LOG_PATH=./audit_logs
STORAGE_BACKEND=memory

# ── Job store (mortgage + insurance async jobs) ──
# auto = use Redis when REDIS_URL/CELERY_BROKER_URL is set, else in-memory
JOB_STORE_BACKEND=auto
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Encryption at rest (Fernet key for audit bundles) ──
# Generate: python -c "from insureflow.storage.encryption import EnvelopeEncryption; print(EnvelopeEncryption.generate_key())"
ENCRYPTION_KEY=

# ── OCR (optional — install with pip install insureflow-ai[ocr]) ──
OCR_ENGINE=auto

# ── API server port (for cli.py serve) ──
API_PORT=8002
