# ── Unified fallback (used if *_CHEAP_* or *_EXPENSIVE_* are not set) ──
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# ── Tier 1: Cheap / fast model for specialist agents (RiskAnalyst, LossRun, etc.) ──
LLM_CHEAP_PROVIDER=openai
LLM_CHEAP_MODEL=gpt-4o-mini
LLM_CHEAP_API_KEY=
# LLM_CHEAP_BASE_URL=http://localhost:8000/v1   # optional: self-hosted vLLM

# ── Tier 2: Expensive / high-quality model for UW decision + conflict resolution ──
LLM_EXPENSIVE_PROVIDER=openai
LLM_EXPENSIVE_MODEL=gpt-4o
LLM_EXPENSIVE_API_KEY=
# LLM_EXPENSIVE_BASE_URL=

# ── Claude / Anthropic (alternative provider) ──
# Set provider to "anthropic" or "claude" to use Claude models
# CLAUDE_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Auth ──
SECRET_KEY=CHANGE_ME_TO_A_LONG_SECRET_KEY_IN_PRODUCTION
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Storage ──
AUDIT_LOG_PATH=./audit_logs
STORAGE_BACKEND=memory

# ── Job store (mortgage + insurance async jobs) ──
# auto = use Redis when REDIS_URL/CELERY_BROKER_URL is set, else in-memory
JOB_STORE_BACKEND=auto
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Encryption at rest (Fernet key for audit bundles) ──
# Generate: python -c "from insureflow.storage.encryption import EnvelopeEncryption; print(EnvelopeEncryption.generate_key())"
ENCRYPTION_KEY=

# ── OCR (optional — install with pip install insureflow-ai[ocr]) ──
OCR_ENGINE=auto

# ── API server port (for cli.py serve) ──
API_PORT=8002

# ── Integration gateway (recommended for production) ──
# Point service URLs at your Rytera gateway, which translates REST → vendor-native APIs.
# Copy this file to .env and paste API keys from your vendor contracts or gateway admin.
# ORACLE_MODE=auto tries live when key+URL are set and health check passes; otherwise simulated.
#
# Gateway (deploy at integrations.rytera.ai or your own host):
#   CLUE_API_URL=https://integrations.rytera.ai/oracles/clue/v2
#   NCCI_API_URL=https://integrations.rytera.ai/oracles/ncci/v2
#   APLUS_API_URL=https://integrations.rytera.ai/oracles/aplus/v2
#   CAT_API_URL=https://integrations.rytera.ai/oracles/cat/v1
#   GUIDEWIRE_API_URL=https://integrations.rytera.ai/policy/guidewire/v1
#   BRITECORE_API_URL=https://integrations.rytera.ai/policy/britecore/v2
#   LOSS_CONTROL_API_URL=https://integrations.rytera.ai/enterprise/loss-control/v1
#   CLAIMS_API_URL=https://integrations.rytera.ai/enterprise/claims/v1
#   BROKER_PORTAL_API_URL=https://integrations.rytera.ai/enterprise/broker-portal/v1
#   ACTUARIAL_API_URL=https://integrations.rytera.ai/enterprise/actuarial/v1
#
# Direct vendor REST (requires carrier contract + vendor-approved endpoints):
#   CLUE_API_URL=https://api.lexisnexis.com/clue/v2
#   NCCI_API_URL=https://api.verisk.com/ncci/v2

# ── External data oracles (simulated | live | auto) ──
ORACLE_MODE=auto
CLUE_API_KEY=
CLUE_API_URL=https://integrations.rytera.ai/oracles/clue/v2
CLUE_QUERY_PATH=/queries

VERISK_API_KEY=
NCCI_API_KEY=
NCCI_API_URL=https://integrations.rytera.ai/oracles/ncci/v2
NCCI_QUERY_PATH=/experience

APLUS_API_KEY=
APLUS_API_URL=https://integrations.rytera.ai/oracles/aplus/v2
APLUS_QUERY_PATH=/queries

CAT_API_KEY=
CAT_API_URL=https://integrations.rytera.ai/oracles/cat/v1
CAT_QUERY_PATH=/model

ISO_RATING_API_KEY=
ISO_RATING_API_URL=https://integrations.rytera.ai/oracles/iso/v1
ISO_RATING_MODE=auto

# ── Policy admin / core systems (auto uses live when URL+key configured and health check passes) ──
GUIDEWIRE_API_KEY=
GUIDEWIRE_API_URL=https://integrations.rytera.ai/policy/guidewire/v1
GUIDEWIRE_USERNAME=
GUIDEWIRE_PASSWORD=
GUIDEWIRE_MODE=auto

BRITECORE_API_KEY=
BRITECORE_API_URL=https://integrations.rytera.ai/policy/britecore/v2
BRITECORE_MODE=auto

# ── Enterprise ecosystem ──
LOSS_CONTROL_API_KEY=
LOSS_CONTROL_API_URL=https://integrations.rytera.ai/enterprise/loss-control/v1
LOSS_CONTROL_MODE=auto

CLAIMS_API_KEY=
CLAIMS_API_URL=https://integrations.rytera.ai/enterprise/claims/v1
CLAIMS_MODE=auto

BROKER_PORTAL_API_KEY=
BROKER_PORTAL_API_URL=https://integrations.rytera.ai/enterprise/broker-portal/v1
BROKER_PORTAL_MODE=auto

ACTUARIAL_API_KEY=
ACTUARIAL_API_URL=https://integrations.rytera.ai/enterprise/actuarial/v1
ACTUARIAL_MODE=auto

HUBSPOT_API_KEY=
HUBSPOT_API_URL=https://api.hubapi.com/crm/v3
HUBSPOT_MODE=auto

INTEGRATION_TIMEOUT_SECONDS=30
INTEGRATION_MAX_RETRIES=3
