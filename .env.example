# ── Unified fallback (used if *_CHEAP_* or *_EXPENSIVE_* are not set) ──
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# ── Tier 1: Cheap / fast model for specialist agents (RiskAnalyst, LossRun, etc.) ──
LLM_CHEAP_PROVIDER=openai
LLM_CHEAP_MODEL=gpt-4o-mini
LLM_CHEAP_API_KEY=
# LLM_CHEAP_BASE_URL=http://localhost:8000/v1   # optional: self-hosted vLLM

# ── Tier 2: Expensive / high-quality model for UW decision + conflict resolution ──
LLM_EXPENSIVE_PROVIDER=openai
LLM_EXPENSIVE_MODEL=gpt-4o
LLM_EXPENSIVE_API_KEY=
# LLM_EXPENSIVE_BASE_URL=

# ── Claude / Anthropic (alternative provider) ──
# Set provider to "anthropic" or "claude" to use Claude models
# CLAUDE_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Auth ──
SECRET_KEY=CHANGE_ME_TO_A_LONG_SECRET_KEY_IN_PRODUCTION
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Bank / production posture ──
# BANK_MODE=true (or ENVIRONMENT=production) enforces:
#   - strong SECRET_KEY, required ENCRYPTION_KEY
#   - open registration OFF, /auth/reset OFF (override with ALLOW_* flags)
ENVIRONMENT=development
BANK_MODE=false
ALLOW_OPEN_REGISTRATION=true
ALLOW_AUTH_RESET=true
MIN_PASSWORD_LENGTH=4
# AWS Secrets Manager (optional — injects missing env keys at boot)
AWS_REGION=us-east-1
AWS_SECRETS_ARN=
CLOUDWATCH_LOGS=false
CLOUDWATCH_NAMESPACE=Rytera/InsureFlow
# WORM examiner retention
WORM_AUDIT_PATH=./audit_logs/worm
AUDIT_RETENTION_DAYS=2555
RETENTION_S3_BUCKET=
# SSO (Cognito / Okta) — optional
SSO_ENABLED=false
SSO_PROVIDER=
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://app.rytera.ai/auth/sso/callback
COGNITO_DOMAIN=
OKTA_DOMAIN=

# ── Storage ──
AUDIT_LOG_PATH=./audit_logs
STORAGE_BACKEND=memory

# ── Job store (mortgage + insurance async jobs) ──
# auto = use Redis when REDIS_URL/CELERY_BROKER_URL is set, else in-memory
JOB_STORE_BACKEND=auto
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Encryption at rest (Fernet key for audit bundles) ──
# Generate: python -c "from insureflow.storage.encryption import EnvelopeEncryption; print(EnvelopeEncryption.generate_key())"
ENCRYPTION_KEY=

# ── OCR (optional — install with pip install insureflow-ai[ocr]) ──
OCR_ENGINE=auto

# ── API server port (for cli.py serve) ──
API_PORT=8002

# ── Rytera integration gateway ──
# Bundled at /integrations on this API server (local + self-hosted production).
# Production DNS: point integrations.rytera.ai → same /integrations routes.
INTEGRATION_GATEWAY_API_KEY=rytera-dev-gateway-key-change-in-production

# ── Integration gateway (recommended for production) ──
# Point service URLs at your Rytera gateway, which translates REST → vendor-native APIs.
# Copy this file to .env — local dev uses 127.0.0.1; production uses integrations.rytera.ai.
# ORACLE_MODE=auto tries live when key+URL are set and health check passes; otherwise simulated.
#
# Production gateway host:
#   CLUE_API_URL=https://integrations.rytera.ai/oracles/clue/v2
#
# Local dev (gateway on same server — no separate deploy needed):
#   CLUE_API_URL=http://127.0.0.1:8002/integrations/oracles/clue/v2

# ── External data oracles (simulated | live | auto) ──
ORACLE_MODE=auto
CLUE_API_KEY=rytera-dev-gateway-key-change-in-production
CLUE_API_URL=http://127.0.0.1:8002/integrations/oracles/clue/v2
CLUE_QUERY_PATH=/queries

VERISK_API_KEY=rytera-dev-gateway-key-change-in-production
NCCI_API_KEY=rytera-dev-gateway-key-change-in-production
NCCI_API_URL=http://127.0.0.1:8002/integrations/oracles/ncci/v2
NCCI_QUERY_PATH=/experience

APLUS_API_KEY=rytera-dev-gateway-key-change-in-production
APLUS_API_URL=http://127.0.0.1:8002/integrations/oracles/aplus/v2
APLUS_QUERY_PATH=/queries

CAT_API_KEY=rytera-dev-gateway-key-change-in-production
CAT_API_URL=http://127.0.0.1:8002/integrations/oracles/cat/v1
CAT_QUERY_PATH=/model

ISO_RATING_API_KEY=rytera-dev-gateway-key-change-in-production
ISO_RATING_API_URL=http://127.0.0.1:8002/integrations/oracles/iso/v1
ISO_RATING_MODE=auto

# ── Policy admin / core systems (auto uses live when URL+key configured and health check passes) ──
GUIDEWIRE_API_KEY=rytera-dev-gateway-key-change-in-production
GUIDEWIRE_API_URL=http://127.0.0.1:8002/integrations/policy/guidewire/v1
GUIDEWIRE_USERNAME=
GUIDEWIRE_PASSWORD=
GUIDEWIRE_MODE=auto

BRITECORE_API_KEY=rytera-dev-gateway-key-change-in-production
BRITECORE_API_URL=http://127.0.0.1:8002/integrations/policy/britecore/v2
BRITECORE_MODE=auto

# ── Enterprise ecosystem ──
LOSS_CONTROL_API_KEY=rytera-dev-gateway-key-change-in-production
LOSS_CONTROL_API_URL=http://127.0.0.1:8002/integrations/enterprise/loss-control/v1
LOSS_CONTROL_MODE=auto

CLAIMS_API_KEY=rytera-dev-gateway-key-change-in-production
CLAIMS_API_URL=http://127.0.0.1:8002/integrations/enterprise/claims/v1
CLAIMS_MODE=auto

BROKER_PORTAL_API_KEY=rytera-dev-gateway-key-change-in-production
BROKER_PORTAL_API_URL=http://127.0.0.1:8002/integrations/enterprise/broker-portal/v1
BROKER_PORTAL_MODE=auto

ACTUARIAL_API_KEY=rytera-dev-gateway-key-change-in-production
ACTUARIAL_API_URL=http://127.0.0.1:8002/integrations/enterprise/actuarial/v1
ACTUARIAL_MODE=auto

HUBSPOT_API_KEY=rytera-dev-gateway-key-change-in-production
HUBSPOT_API_URL=http://127.0.0.1:8002/integrations/crm/hubspot/v3
HUBSPOT_MODE=auto

INTEGRATION_TIMEOUT_SECONDS=30
INTEGRATION_MAX_RETRIES=3

# ── LangSmith cloud eval tracking & LangGraph tracing ──
# Dashboard: https://smith.langchain.com
# Create an API key at Settings → API Keys, then:
#   pip install -e ".[eval]"
#   python -m evaluations.report
# Metrics (precision/recall/hallucination/Ragas/Giskard) upload automatically.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=insureflow-evals
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_TRACING=true

# Optional MLflow for agent release experiments (falls back to evaluation_experiments/)
MLFLOW_TRACKING_URI=
MLFLOW_EXPERIMENT_NAME=insureflow-agent-releases

# RAG retrieval (top-k, over-fetch, re-rank, fallbacks)
RAG_TOP_K=5
RAG_FETCH_K=15
RAG_PIPELINE_TOP_K=3
RAG_MIN_VECTOR_SCORE=0.12
RAG_ENABLE_RERANK=true
RAG_ENABLE_KEYWORD_FALLBACK=true
RAG_ENABLE_KG_FALLBACK=true
# Optional: sentence-transformers cross-encoder model name
RAG_CROSS_ENCODER_MODEL=
# Aliases also supported: LANGCHAIN_API_KEY, LANGCHAIN_TRACING_V2, LANGCHAIN_PROJECT
